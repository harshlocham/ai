{
  "include": ["src/**/*.js", "vite.config.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    "allowJs": true,
    "checkJs": false,

    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "noEmit": true,

    "skipLibCheck": true,
    "strict": true,
    "noUncheckedSideEffectImports": true
  }
}
